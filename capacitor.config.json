{
  "appId": "com.atlasoon.anacan",
  "appName": "Anacan",
  "webDir": "dist",
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#FAF7F4",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#F97316"
    },
    "Camera": {
      "permissionText": "Tətbiq nəcis skaneri və şəkil yükləmək üçün kameraya ehtiyac duyur"
    },
    "Geolocation": {
      "permissionText": "Tətbiq hava vəziyyəti və geyim tövsiyələri üçün məkanınıza ehtiyac duyur"
    }
  },
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#FAF7F4"
  },
  "android": {
    "includePlugins": [
      "@capacitor-firebase/analytics",
      "@capacitor-firebase/messaging",
      "@capacitor/app",
      "@capacitor/camera",
      "@capacitor/filesystem",
      "@capacitor/geolocation",
      "@capacitor/haptics",
      "@capacitor/local-notifications",
      "@capacitor/preferences",
      "@capacitor/push-notifications",
      "@capacitor/splash-screen",
      "@capacitor/status-bar",
      "@revenuecat/purchases-capacitor",
      "@revenuecat/purchases-capacitor-ui"
    ],
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#FAF7F4"
  },
  "server": {
    "hostname": "app.anacan.az",
    "androidScheme": "https"
  }
}
